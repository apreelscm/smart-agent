                        <tr id="trBase"><td></td><td style="text-align: right;"><g:message code="panel.base"/></td><td><g:field id="oplPOSBaza" name="oplPOSBaza" type="number" value="${data.oplPOSBaza}" style="width: 50px"/> <g:message code="panel.unit"/> </td><td></td><td></td><td></td><td></td><td></td></tr>
