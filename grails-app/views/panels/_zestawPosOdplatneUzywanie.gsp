                </table>
            </div>
        </div>
    </fieldset>
</div>

<r:script>
    jQuery(document).ready(function() {
        jQuery("#oplPOSGPRSTyp").change(verifyBaseVisibility)
        verifyBaseVisibility()
    });

    function verifyBaseVisibility(){
        var value = jQuery("#oplPOSGPRSTyp").val().toString()
        if(value == "Verifone Vx670 GPRS"){
            jQuery("#trBase").show()
        }
        else{
            jQuery("#trBase").hide()
        }
    }
</r:script>
