     <sql-query name="QUERY_NAME_FIND_EMAIL">
		<return entity-name="com.eservice.orm.CbtEmail"/>
SELECT   e.*
    FROM   cbt_email e
   WHERE   eml_id IN
                 (SELECT   DISTINCT (eml_id)
                    FROM   (SELECT   DISTINCT (eml_id)
                              FROM   cbt_sprawy_hist a,
                                     cbt_sprawy_hist b,
                                     cbt_terminale_pos,
                                     cbt_email e,
                                     cbt_przedstawicieleh_interw
                             WHERE       a.shi_tps_id = tps_id
                                     AND b.shi_tps_id = tps_id
                                     AND tps_numer_logiczny = :p_pos_id
                                     AND a.shi_spr_id = b.shi_spr_id
                                     AND phi_numer = eml_phi_numer
                                     AND phi_shi_id = a.shi_id
                                     AND eml_rodzaj = 'W'
                            UNION ALL
                            SELECT   DISTINCT (eml_id)
                              FROM   cbt_sprawy_hist a,
                                     cbt_sprawy_hist b,
                                     cbt_terminale_pos,
                                     cbt_email e
                             WHERE       a.shi_tps_id = tps_id
                                     AND b.shi_tps_id = tps_id
                                     AND tps_numer_logiczny = :p_pos_id
                                     AND a.shi_spr_id = b.shi_spr_id
                                     AND eml_shi_id = b.shi_id
                                     AND eml_rodzaj = 'W'
                            UNION ALL
                            SELECT   DISTINCT (eml_id)
                              FROM   cbt_email e,
                                     cbt_sprawy_hist a,
                                     cbt_sprawy_hist b,
                                     cbt_przedstawicieleh_interw
                             WHERE   phi_shi_id = a.shi_id AND phi_numer = :p_phi_numer
                                     AND (eml_phi_numer = phi_numer
                                          OR eml_shi_id = b.shi_id)
                                     AND a.shi_spr_id = b.shi_spr_id
                                     AND (a.shi_tps_id IS NULL
                                          OR (a.shi_tps_id IS NOT NULL
                                              AND b.shi_tps_id = a.shi_tps_id))
                                     AND eml_rodzaj = 'W'
                            UNION ALL
                            SELECT   DISTINCT (eml_id)
                              FROM   cbt_email,
                                     cbt_sprawy_hist a,
                                     cbt_sprawy_hist b,
                                     cbt_przedstawicieleh_interw
                             WHERE       phi_shi_id = a.shi_id
                                     AND a.shi_spr_id = b.shi_spr_id
                                     AND a.shi_spr_id = :p_spr_id
                                     AND b.shi_spr_id = :p_spr_id
                                     AND (phi_numer = eml_phi_numer
                                          OR eml_shi_id = b.shi_id)
                                     AND eml_rodzaj = 'W'
                            UNION ALL
                            SELECT   DISTINCT (eml_id)
                              FROM   cbt_email, cbt_przedstawicieleh_interw
                             WHERE       phi_shi_id = :p_shi_id
                                     AND eml_phi_numer = phi_numer
                                     AND eml_rodzaj = 'W'
                            UNION ALL
                            SELECT   DISTINCT (eml_id)
                              FROM   cbt_email
                             WHERE   eml_shi_id = :p_shi_id AND eml_rodzaj = 'W'))
ORDER BY   eml_id DESC
