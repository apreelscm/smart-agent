<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping>

    <class name="com.eservice.orm.AdmAplikacje" table="ADM_APLIKACJE"
           schema="CBD_ADM">
        <id name="id" type="java.lang.Long">
            <column name="APL_ID" precision="10" scale="0" />
            <generator class="sequence" />
        </id>
        <property name="nazwa" type="java.lang.String">
            <column name="APL_NAZWA" length="250" />
        </property>
        <property name="code" type="java.lang.Long">
            <column name="APL_KOD" length="3" unique="true"  />
        </property>
    </class>

    <sql-query name="findCbdModuleRoles" callable="true" >
        <return class="com.eservice.orm.AdmModuly">
            <return-property name="id" column="MOD_ID" />
            <return-property name="typ" column="MOD_TYP" />
            <return-property name="nazwa" column="MOD_NAZWA" />
            <return-property name="aplId" column="MOD_APL_ID" />
            <return-property name="rola" column="ROL_NAZWA" />
        </return>
        { call Adm_WEB.FIND_MODULES_ROLE (?, :appcode) }
    </sql-query>

</hibernate-mapping>
