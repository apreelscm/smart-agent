<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping>

    <class name="com.eservice.orm.AdmExtAppLogin" table="ADM_EXTAPP_LOGINS"
           schema="CBD_ADM">

        <id name="id" type="java.lang.Long">
            <column name="EPL_ID" precision="10" scale="0" />
            <generator class="sequence" />
        </id>

        <many-to-one name="user" class="com.eservice.orm.AdmUzytkownicyWeb"
			fetch="join">
			<column name="EPL_AUW_ID" precision="10" scale="0" />
		</many-to-one>

        <property name="extApp" type="java.lang.String">
            <column name="EPL_EXT_APP" length="30" />
        </property>
        <property name="login" type="java.lang.String">
            <column name="EPL_LOGIN" length="30" />
        </property>
        <property name="password" type="java.lang.String">
            <column name="EPL_PASS" precision="30"/>
        </property>
    </class>

</hibernate-mapping>
