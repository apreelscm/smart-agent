     <sql-query name="QUERY_NAME_FIND_PREPAID_STRUKTURA_KLIENTA_CBD">
		<return entity-name="com.eservice.orm.cbdweb.prepaid.CbtStrukturaKlienta"/>
      SELECT   KLN_ID,
             KLN_KLN_ID,
             KLN_NAZWA,
             KLN_MID,
             (SELECT   rv_meaning
                FROM   cg_ref_codes
               WHERE   rv_domain = 'LW_STATUS_KLIENTA'
                       AND rv_low_value = KLN_STATUS)
                AS KLN_STATUS_LW,
             KLN_POZIOM,
             (SELECT   rv_meaning
                FROM   cg_ref_codes
               WHERE   rv_domain = 'LW_POZIOM_MERCHANTA'
                       AND rv_low_value = KLN_POZIOM)
                AS KLN_POZIOM_LW
      FROM   cbt_klienci
START WITH   kln_id IN ( -- kln_id merchantow, ktorzy maja w sobie punkty, spelniajace warunek
                        SELECT       kln_id
                              FROM   cbt_klienci
                             WHERE   kln_poziom = 'MRC'
                        START WITH   kln_id = :klnId
                        CONNECT BY   PRIOR kln_kln_id = kln_id)
CONNECT BY   PRIOR kln_id = kln_kln_id
-- terminale, ktore maja w powyzszej liscie odpowiednika
UNION ALL
SELECT   tps_id,
         tps_kln_id,
         'Terminal ID',
         tps_numer_logiczny,
         (SELECT   rv_meaning
            FROM   cg_ref_codes
           WHERE   rv_domain = 'LW_STATUS_TERMINALA_POS'
                   AND rv_low_value = tps_status),
         'TRM',
         'Terminal POS'
  FROM   cbt_terminale_pos
 WHERE   tps_kln_id IN
               (    SELECT   kln_id
                      FROM   cbt_klienci
                     WHERE   kln_poziom = 'OUT'
                START WITH   kln_id IN
                                   ( -- kln_id merchantow, ktorzy maja w sobie punkty, spelniajace warunek
                                    SELECT       kln_id
                                          FROM   cbt_klienci
                                         WHERE   kln_poziom = 'MRC'
                                    START WITH   kln_id = :klnId
                                    CONNECT BY   PRIOR kln_kln_id = kln_id)
                CONNECT BY   PRIOR kln_id = kln_kln_id)
	</sql-query>
        
