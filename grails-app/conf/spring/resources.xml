<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation=" http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-2.5.xsd">


    <bean id="passwordEncryptor" class="org.jasypt.util.password.ConfigurablePasswordEncryptor">
        <property name="config" ref="SimpleDigesterConfig" />
        <property name="stringOutputType" value="base64" />
    </bean>

    <bean id="SimpleDigesterConfig" class="org.jasypt.digest.config.SimpleDigesterConfig">
        <property name="algorithm" value="SHA-1" />
        <property name="iterations" value="1000" />
        <property name="saltGenerator" ref="SaltGenerator" />
        <property name="saltSizeBytes" value="8" />
    </bean>

    <bean id="SaltGenerator" class="org.jasypt.salt.RandomSaltGenerator" />

    <bean id="UserDAO" class="com.eservice.dao.emetrics.UserDAO">
        <property name="sessionFactory">
            <ref bean="sessionFactoryExt" />
        </property>
    </bean>
    <bean id="roleService" class="com.eservice.service.security.NoRoleService"/>

    <bean id="userService" class="com.eservice.service.security.UserService">
        <property name="roleService">
            <ref bean="roleService" />
        </property>
        <property name="userDAO">
            <ref bean="UserDAO" />
        </property>
        <property name="passwordEncryptor" ref="passwordEncryptor" />
        <property name="sessionFactory">
            <ref bean="sessionFactoryExt" />
        </property>
    </bean>

    <bean id="dataSourceExt" class="org.springframework.jdbc.datasource.DriverManagerDataSource">
        <property name="driverClassName" value="org.h2.Driver" />
        <property name="url" value="jdbc:h2:mem:CbdDb;MVCC=TRUE;LOCK_TIMEOUT=10000" />
        <property name="username" value="sa" />
        <property name="password" value="" />
    </bean>

    <bean id="sessionFactoryExt"
          class="org.springframework.orm.hibernate3.LocalSessionFactoryBean">
        <property name="dataSource">
            <ref bean="dataSourceExt" />
        </property>
        <property name="hibernateProperties">
            <props>
                <prop key="hibernate.dialect">
                    org.hibernate.dialect.Oracle10gDialect
                </prop>
                <prop key="hibernate.query.substitutions">true=1 false=0</prop>
                <prop key="hibernate.bytecode.use_reflection_optimizer">false</prop>
                <prop key="hibernate.show_sql">false</prop>
                <prop key="hibernate.format_sql">true</prop>
                <prop key="hibernate.use_sql_comments">false</prop>
            </props>
        </property>

        <property name="mappingResources">
